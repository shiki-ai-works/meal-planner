{
  "name": "meal-planner",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "npm run setup:doctor:test && npm run recipe-images:workflow:test && npm run e2e:public:test && npm run portfolio:check:test && npm run portfolio:check && npm run docs:links:test && npm run docs:links && npm run docs:mojibake:test && npm run docs:mojibake && npm run docs:progress-index:test && npm run docs:progress-index && npm run recipe-images:workflow && npm run typecheck && npm run lint && npm run build",
    "e2e:public": "npm run build && node scripts/e2e-public-flow.mjs",
    "e2e:public:run": "node scripts/e2e-public-flow.mjs",
    "e2e:public:test": "node scripts/e2e-public-flow.test.mjs",
    "release:check": "npm run check && npm run recipe-images:sources-check:strict && npm run e2e:public:run",
    "portfolio:check": "node scripts/check-portfolio-assets.mjs",
    "portfolio:check:test": "node scripts/check-portfolio-assets.test.mjs",
    "docs:links": "node scripts/check-doc-links.mjs",
    "docs:links:test": "node scripts/check-doc-links.test.mjs",
    "docs:mojibake": "node scripts/check-doc-mojibake.mjs",
    "docs:mojibake:test": "node scripts/check-doc-mojibake.test.mjs",
    "docs:progress-index": "node scripts/check-progress-index.mjs",
    "docs:progress-index:test": "node scripts/check-progress-index.test.mjs",
    "deploy:production": "node scripts/deploy-production.mjs",
    "setup:doctor": "node scripts/check-supabase-env.mjs",
    "setup:doctor:strict": "node scripts/check-supabase-env.mjs --strict",
    "setup:doctor:json": "node scripts/check-supabase-env.mjs --json",
    "setup:doctor:help": "node scripts/check-supabase-env.mjs --help",
    "setup:doctor:test": "node scripts/check-supabase-env.test.mjs",
    "recipe-images:sql": "node scripts/generate-recipe-image-sql.mjs",
    "recipe-images:sql-strict": "node scripts/generate-recipe-image-sql.mjs --strict --require-seed-recipes",
    "recipe-images:migration": "node scripts/generate-recipe-image-sql.mjs --strict --require-seed-recipes --output supabase/migrations/007_recipe_images.sql",
    "recipe-images:template": "node scripts/generate-recipe-image-sql.mjs --print-template",
    "recipe-images:init-actual": "node scripts/generate-recipe-image-sql.mjs --template-output supabase/recipe-images.actual.json",
    "recipe-images:workflow": "node scripts/generate-recipe-image-sql.mjs --workflow",
    "recipe-images:workflow:json": "node scripts/generate-recipe-image-sql.mjs --workflow-json",
    "recipe-images:workflow:schema": "node scripts/generate-recipe-image-sql.mjs --workflow-schema",
    "recipe-images:workflow:test": "node scripts/generate-recipe-image-sql.test.mjs",
    "recipe-images:sources-check": "node scripts/generate-recipe-image-sql.mjs --sources-check",
    "recipe-images:sources-check:strict": "node scripts/generate-recipe-image-sql.mjs --sources-check --strict",
    "recipe-images:sources-report": "node scripts/generate-recipe-image-sql.mjs --sources-report",
    "recipe-images:sources-report:json": "node scripts/generate-recipe-image-sql.mjs --sources-report-json",
    "recipe-images:sources-report:markdown": "node scripts/generate-recipe-image-sql.mjs --sources-report-markdown",
    "recipe-images:actual-workflow": "node scripts/generate-recipe-image-sql.mjs --workflow",
    "recipe-images:actual-report": "node scripts/generate-recipe-image-sql.mjs --report --allow-empty --require-seed-recipes supabase/recipe-images.actual.json",
    "recipe-images:actual-missing": "node scripts/generate-recipe-image-sql.mjs --list-missing-images --missing-markdown --allow-empty --require-seed-recipes supabase/recipe-images.actual.json",
    "recipe-images:actual-todo": "node scripts/generate-recipe-image-sql.mjs --list-missing-images --missing-markdown --allow-empty --require-seed-recipes --missing-output supabase/recipe-images.todo.md supabase/recipe-images.actual.json",
    "recipe-images:actual-check": "node scripts/generate-recipe-image-sql.mjs --check --strict --require-seed-recipes supabase/recipe-images.actual.json",
    "recipe-images:actual-migration": "node scripts/generate-recipe-image-sql.mjs --strict --require-seed-recipes --output supabase/migrations/007_recipe_images.sql supabase/recipe-images.actual.json",
    "recipe-images:report": "node scripts/generate-recipe-image-sql.mjs --report --allow-empty --require-seed-recipes",
    "recipe-images:missing": "node scripts/generate-recipe-image-sql.mjs --list-missing-images --allow-empty --require-seed-recipes",
    "recipe-images:missing-md": "node scripts/generate-recipe-image-sql.mjs --list-missing-images --missing-markdown --allow-empty --require-seed-recipes",
    "recipe-images:missing-md-file": "node scripts/generate-recipe-image-sql.mjs --list-missing-images --missing-markdown --allow-empty --require-seed-recipes --missing-output supabase/recipe-images.todo.md",
    "recipe-images:check": "node scripts/generate-recipe-image-sql.mjs --check",
    "recipe-images:check-strict": "node scripts/generate-recipe-image-sql.mjs --check --strict --require-seed-recipes",
    "recipe-images:check-generated-template": "node scripts/generate-recipe-image-sql.mjs --check-generated-template supabase/recipe-images.template.json",
    "recipe-images:check-template": "node scripts/generate-recipe-image-sql.mjs --check --allow-empty --require-seed-recipes supabase/recipe-images.template.json"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
