# env files (can opt-in for committing if needed)
.env*
!.env.example

# local recipe image URL working files
/supabase/recipe-images.actual.json
/supabase/recipe-images.todo.md
/supabase/recipe-images.sources.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
